# Discord OAuth2 — Create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback

# Discord server (guild) ID — required for membership check
DISCORD_GUILD_ID=your_guild_id

# Comma-separated Discord role IDs that are allowed to nominate
# (Ascendant, bitty, ritty, Ritualist, Radiant Ritualist)
NOMINATOR_ROLE_IDS=role_id_1,role_id_2,role_id_3,role_id_4,role_id_5

# Session secret — any random string (use: openssl rand -hex 32)
SESSION_SECRET=your_random_secret_here

# Upstash Redis — Create free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
